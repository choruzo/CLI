{
  "provider": {
    "default": "local-ollama",
    "providers": {
      "local-ollama": {
        "type": "openai-compatible",
        "baseUrl": "http://localhost:11434/v1",
        "model": "qwen3.5:9b",
        "apiKey": "ollama",
        "contextWindow": 32768
      },
      "litellm-proxy": {
        "type": "openai-compatible",
        "baseUrl": "http://localhost:4000/v1",
        "model": "claude-sonnet-4-5",
        "apiKey": "${LITELLM_API_KEY}",
        "contextWindow": 200000
      }
    }
  },
  "memory": {
    "projectFile": "./STRATUM.md",
    "globalFile": "~/.stratum/STRATUM.md",
    "decisionsFile": "~/.stratum/memory/decisions.json",
    "vectorDb": "~/.stratum/memory/vectors.db",
    "embeddingModel": "Xenova/all-MiniLM-L6-v2",
    "embeddingDimension": 384,
    "embeddingEndpoint": {
      "url": "http://localhost:11434/v1/embeddings",
      "model": "all-minilm",
      "apiKey": ""
    },
    "retrievalTopK": 5,
    "similarityThreshold": 0.9,
    "autoExtract": true,
    "extractionModel": "qwen3.5:9b",
    "embeddingWarmup": false
  },
  "tools": {
    "confirmDestructive": true,
    "bashTimeout": 30000,
    "webSearch": {
      "backend": "meta",
      "tavilyApiKey": "${TAVILY_API_KEY}",
      "maxResults": 10
    },
    "destructivePatterns": ["rm", "rmdir", "dd", "mkfs", "format", "DROP", "DELETE", "truncate", "shred", "wipefs"]
  },
  "mcp": {
    "startup": "lazy",
    "installDir": "~/.stratum/mcp",
    "autoInstall": true,
    "heartbeatInterval": 30000,
    "servers": [
      {
        "name": "filesystem",
        "package": "@modelcontextprotocol/server-filesystem@2025.8.21",
        "args": ["/home/user/projects"],
        "startupTimeout": 15000
      },
      {
        "name": "chrome-devtools",
        "package": "chrome-devtools-mcp@0.6.0"
      },
      {
        "name": "legacy-npx",
        "command": "npx",
        "args": ["-y", "some-mcp-server@latest"]
      }
    ]
  },
  "agent": {
    "maxIterations": 50,
    "maxToolRetries": 3,
    "toolErrorFormat": "xml",
    "compressionKeepRounds": 6
  },
  "logging": {
    "level": "info",
    "stderr": true,
    "redact": true,
    "file": {
      "enabled": false,
      "dir": "~/.stratum/logs",
      "maxBytes": 5242880,
      "maxFiles": 5
    }
  }
}
